<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="383dp"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    app:behavior_hideable="true"
    app:behavior_peekHeight="240dp"
    android:visibility="gone">

    <View
        android:layout_width="50dp"
        android:layout_height="4dp"
        android:layout_marginTop="@dimen/icon_padding"
        android:layout_marginBottom="@dimen/small_padding"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bottom_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/small_padding"
        android:paddingVertical="@dimen/icon_padding">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/menu_cover"
            android:layout_width="@dimen/artwork_size"
            android:layout_height="@dimen/artwork_size"
            android:contentDescription="@string/art"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_45"
            app:shapeAppearanceOverlay="@style/RoundedCornersOverlay2" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/icon_padding"
            android:paddingTop="6dp"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/menu_playlist_name"
                style="@style/Text16"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Best songs 2021" />

            <TextView
                android:id="@+id/menu_playlist_track_count"
                style="@style/Text11"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                tools:text="98 треков" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="@dimen/icon_padding"
        android:background="@color/gray" />

    <TextView
        android:id="@+id/btn_share"
        style="@style/Text16"
        android:layout_width="match_parent"
        android:layout_height="@dimen/large_size"
        android:gravity="center_vertical|start"
        android:paddingHorizontal="@dimen/medium_padding"
        android:text="@string/send2" />

    <TextView
        android:id="@+id/btn_edit"
        style="@style/Text16"
        android:layout_width="match_parent"
        android:layout_height="@dimen/large_size"
        android:gravity="center_vertical|start"
        android:paddingHorizontal="@dimen/medium_padding"
        android:text="@string/edit" />

    <TextView
        android:id="@+id/btn_delete_playlist"
        style="@style/Text16"
        android:layout_width="match_parent"
        android:layout_height="@dimen/large_size"
        android:gravity="center_vertical|start"
        android:paddingHorizontal="@dimen/medium_padding"
        android:text="@string/delete_playlist" />

</LinearLayout>