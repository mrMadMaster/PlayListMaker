<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/finish_creating_playlist"
        android:textColor="@android:color/black"
        android:textSize="14sp"
        android:textFontWeight="400"
        android:layout_marginStart="@dimen/top_padding"
        android:layout_marginEnd="@dimen/icon_padding"
        android:layout_marginTop="23dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/unsaved_data_will_be_lost"
        android:textColor="@android:color/black"
        android:textSize="14sp"
        android:textFontWeight="400"
        android:layout_marginStart="@dimen/top_padding"
        android:layout_marginEnd="@dimen/icon_padding"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="end|bottom"
        android:layout_marginStart="@dimen/top_padding"
        android:layout_marginEnd="@dimen/icon_padding"
        android:layout_marginBottom="@dimen/icon_padding">

        <Button
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@color/blue"
            android:textSize="@dimen/small_text_size" />

        <Button
            android:id="@+id/btnFinish"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/finish"
            android:textColor="@color/blue"
            android:textSize="@dimen/small_text_size"
            android:layout_marginStart="@dimen/medium_padding" />

    </LinearLayout>

</LinearLayout>