<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    app:behavior_hideable="true"
    app:behavior_peekHeight="240dp"
    android:visibility="gone">

    <View
        android:layout_width="50dp"
        android:layout_height="4dp"
        android:layout_marginTop="@dimen/icon_padding"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bottom_sheet_handle" />

    <TextView
        style="@style/Text19_500"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center"
        android:layout_marginTop="@dimen/small_padding"
        android:text="@string/add_to_playlist" />

    <com.google.android.material.button.MaterialButton
        style="@style/NewPlaylistButton"
        android:id="@+id/btnNewPlaylist"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/medium_padding"
        android:layout_marginBottom="@dimen/top_padding"
        android:text="@string/new_playlist" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playlistsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false" />

</LinearLayout>