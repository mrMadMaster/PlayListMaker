<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivCover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:shapeAppearanceOverlay="@style/RoundedCornersOverlay2"
        android:layout_marginStart="13dp"
        android:layout_marginVertical="8dp"
        android:contentDescription="@string/art"
        android:scaleType="centerCrop"
        android:src="@drawable/placeholder_45"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivCover"
        app:layout_constraintTop_toTopOf="parent">

        <TextView style="@style/Text16"
            android:id="@+id/playlist_name2"
            tools:text="Playlist Name"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="@id/ivCover"
            app:layout_constraintTop_toBottomOf="@id/playlist_name2"
            android:gravity="start"/>

        <TextView style="@style/Text11"
            android:id="@+id/playlist_track_count2"
            tools:text="0 треков"
            android:layout_marginTop="1dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>